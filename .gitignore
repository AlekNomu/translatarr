# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Distribution / packaging ──────────────────────────────────────────────────
.Python
build/
dist/
eggs/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# ── Linting cache ─────────────────────────────────────────────────────────────
.ruff_cache/

# ── Build artefacts ───────────────────────────────────────────────────────────
*.egg-info/

# ── Whisper model cache ───────────────────────────────────────────────────────
# (large binary files — download on demand, do not commit)
~/.cache/whisper/

# ── Media files ───────────────────────────────────────────────────────────────
*.mkv
*.mp4
*.avi
*.mov
*.wav
*.mp3

# ── Generated subtitles ───────────────────────────────────────────────────────
# Uncomment to ignore all generated .srt files
# *.srt

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Frontend (Vue/Vite) ──────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
translatarr_web/static/

# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock IS committed (reproducible builds) — only ignore the cache
.uv/

# ── Docker ────────────────────────────────────────────────────────────────────
docker/config/

# ── Runtime config & database ─────────────────────────────────────────────────
config/
*.db
*.db-shm
*.db-wal

# ── Generated subtitles (root-level test artefacts) ──────────────────────────
subtitles_*.srt
